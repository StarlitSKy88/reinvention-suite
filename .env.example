# ============================================
# Reinvention Suite — Root Environment Variables
# ============================================
# Copy this file to `.env` and fill in your secrets.
# NEVER commit `.env` to git!

# ============================================
# AI Provider API Keys
# ============================================

# MiniMax-M3 (主推理 — 您指定)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-M3

# Claude Sonnet 4.6 (高质量场景)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# DeepSeek-V3 (成本兜底)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# Search APIs
# ============================================

# Exa Search (公司官网搜索)
EXA_API_KEY=your_exa_api_key_here

# Tavily (深度研究)
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# Database
# ============================================

DATABASE_URL=postgresql://user:password@localhost:5432/reinvention
REDIS_URL=redis://localhost:6379

# ============================================
# Auth (NextAuth)
# ============================================

NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# 微信开放平台（小程序 + 公众号）
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# ============================================
# Scraping Service (Python FastAPI)
# ============================================

SCRAPER_SERVICE_URL=http://localhost:8000
SCRAPER_API_KEY=your_scraper_api_key_here

# ============================================
# Observability
# ============================================

SENTRY_DSN=your_sentry_dsn_here
POSTHOG_API_KEY=your_posthog_api_key_here

# ============================================
# Government Dashboard (To-G)
# ============================================

GOV_DASHBOARD_URL=http://localhost:3001
GOV_API_KEY=your_gov_api_key_here

# ============================================
# Feature Flags
# ============================================

ENABLE_USER_SCRAPING=true          # 用户授权爬虫开关
ENABLE_GOV_DASHBOARD=true          # 政府看板开关
ENABLE_PRO_MODE=false              # Pro 模式开关（MVP 阶段关闭）
