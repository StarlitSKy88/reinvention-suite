# ============================================
# Web App Local Environment (for Next.js)
# ============================================
# Copy to `.env.local` for local development.

# MiniMax-M3 主推理
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-M3

# Claude 高质量场景
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek 兜底
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 搜索 API
EXA_API_KEY=your_exa_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Scraper Service（本地 Python 微服务）
SCRAPER_SERVICE_URL=http://localhost:8000
SCRAPER_API_KEY=dev_scraper_key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/reinvention
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_SECRET=dev_secret_change_in_production
NEXTAUTH_URL=http://localhost:3000

# Feature Flags
ENABLE_USER_SCRAPING=true
ENABLE_GOV_DASHBOARD=true
ENABLE_PRO_MODE=false
